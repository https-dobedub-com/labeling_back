# APP
NODE_ENV=local
APP_NAME=labeling-back
SERVER_PORT=3000
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# DATABASE
DB_TYPE=mysql
DB_SYNCHRONIZE=false
DB_LOGGING=false
SQLITE_DATABASE=labeling.sqlite

# MYSQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=1234
MYSQL_DATABASE=labeling

# COPY SCRIPT - SOURCE DB
SOURCE_DB_HOST=
SOURCE_DB_PORT=3306
SOURCE_DB_USER=
SOURCE_DB_PASSWORD=
SOURCE_DB_NAME=

# COPY SCRIPT - TARGET DB
TARGET_DB_HOST=
TARGET_DB_PORT=3306
TARGET_DB_USER=
TARGET_DB_PASSWORD=
TARGET_DB_NAME=

